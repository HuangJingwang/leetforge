# === 备用方式：手动配置（推荐使用 leetcode --login 自动登录） ===

# LeetCode CN 用户名（即个人主页 URL 中的 userSlug）
# 例如 https://leetcode.cn/u/your-username/ 中的 your-username
LEETCODE_USERNAME=

# 从浏览器开发者工具获取（F12 -> Application -> Cookies -> leetcode.cn）
LEETCODE_SESSION=
CSRF_TOKEN=

# 刷题计划文件夹路径（默认为 ~/Desktop/刷题计划）
# PLAN_DIR=~/Desktop/刷题计划
